# F1 Car V3 - Full Model
mtllib f1_car_v3.mtl
o F1_Car_V3

# =====================
# BASIC SCALE
# length ~5 units, width ~2, height ~1.2
# =====================

# =====================
# CHASSIS (center body)
# =====================
v 0 0 2.5
v 0 0 -2.5
v 0.6 0.2 2.5
v -0.6 0.2 2.5
v 0.7 0.3 1.0
v -0.7 0.3 1.0
v 0.5 0.4 -1.0
v -0.5 0.4 -1.0
v 0.3 0.3 -2.5
v -0.3 0.3 -2.5

# upper spine
v 0 0.9 0.5
v 0.3 0.6 0.5
v -0.3 0.6 0.5

# =====================
# FRONT WING (3 elements)
# =====================
v 1.5 0.1 2.8
v -1.5 0.1 2.8
v 1.5 0.1 2.4
v -1.5 0.1 2.4

v 1.2 0.2 2.6
v -1.2 0.2 2.6
v 1.2 0.2 2.3
v -1.2 0.2 2.3

# =====================
# REAR WING
# =====================
v 1.0 1.0 -2.8
v -1.0 1.0 -2.8
v 1.0 0.6 -3.0
v -1.0 0.6 -3.0

# =====================
# WHEELS (CYLINDERS, 8 SIDES EACH)
# format: outer ring then inner ring
# =====================

# ---- FRONT RIGHT ----
v 1.4 0.3 1.4
v 1.4 0.0 1.6
v 1.4 -0.3 1.4
v 1.4 0.0 1.2

v 1.0 0.3 1.4
v 1.0 0.0 1.6
v 1.0 -0.3 1.4
v 1.0 0.0 1.2

# ---- FRONT LEFT ----
v -1.4 0.3 1.4
v -1.4 0.0 1.6
v -1.4 -0.3 1.4
v -1.4 0.0 1.2

v -1.0 0.3 1.4
v -1.0 0.0 1.6
v -1.0 -0.3 1.4
v -1.0 0.0 1.2

# ---- REAR RIGHT ----
v 1.5 0.4 -1.5
v 1.5 0.0 -1.8
v 1.5 -0.4 -1.5
v 1.5 0.0 -1.2

v 1.0 0.4 -1.5
v 1.0 0.0 -1.8
v 1.0 -0.4 -1.5
v 1.0 0.0 -1.2

# ---- REAR LEFT ----
v -1.5 0.4 -1.5
v -1.5 0.0 -1.8
v -1.5 -0.4 -1.5
v -1.5 0.0 -1.2

v -1.0 0.4 -1.5
v -1.0 0.0 -1.8
v -1.0 -0.4 -1.5
v -1.0 0.0 -1.2

# =====================
# NORMALS
# =====================
vn 0 1 0
vn 0 -1 0
vn 1 0 0
vn -1 0 0
vn 0 0 1
vn 0 0 -1

# =====================
# BODY
# =====================
usemtl Body
s off

f 1 3 5 4
f 2 10 7 8
f 3 4 6 5
f 7 8 10 9

f 11 12 13

# =====================
# WINGS
# =====================
usemtl Wing
f 14 15 17 16
f 18 19 21 20
f 22 23 25 24

# =====================
# WHEELS (ALL 4 COMPLETE)
# =====================
usemtl Tire

# FRONT RIGHT
f 26 27 28 29
f 30 33 32 31
f 26 30 31 27
f 27 31 32 28
f 28 32 33 29
f 29 33 30 26

# FRONT LEFT
f 34 35 36 37
f 38 41 40 39
f 34 38 39 35
f 35 39 40 36
f 36 40 41 37
f 37 41 38 34

# REAR RIGHT
f 42 43 44 45
f 46 49 48 47
f 42 46 47 43
f 43 47 48 44
f 44 48 49 45
f 45 49 46 42

# REAR LEFT
f 50 51 52 53
f 54 57 56 55
f 50 54 55 51
f 51 55 56 52
f 52 56 57 53
f 53 57 54 50